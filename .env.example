# OAuth2 Proxy Configuration
# Copy this file to .env and fill in your values

# Generate a random cookie secret (exactly 32 characters):
# python3 -c "import secrets; print(secrets.token_urlsafe(24))"
OAUTH2_PROXY_COOKIE_SECRET=

# Google OAuth2 credentials
# Create at: https://console.cloud.google.com/apis/credentials
# Set Authorized redirect URI to: http://localhost:8081/oauth2/callback
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=s

# Gemini AI API Key (optional - enables AI-powered ICA shopping)
# Get your API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# SQLite + Litestream replication (optional)
# Set LITESTREAM_ENABLED=true to restore/replicate recipes.db to S3.
LITESTREAM_ENABLED=false
LITESTREAM_S3_BUCKET=
LITESTREAM_S3_PREFIX=matsedel

# AWS credentials for S3 access
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
